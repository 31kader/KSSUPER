# Gemini API Key for AI features
GEMINI_API_KEY=

# Supabase Credentials (Client-side Config)
# You can use either VITE_ prefix or NEXT_PUBLIC_ prefix
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public App URL for OAuth Redirects (e.g. https://your-app.run.app)
VITE_APP_URL=

NODE_ENV=development
